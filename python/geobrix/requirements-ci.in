# Source of truth for CI Python deps consumed by .github/actions/{scala,python}_build.
# Edit this file, then regenerate the hash-pinned lock:
#
#   cd python/geobrix
#   uv pip compile --generate-hashes --python-version 3.12 \
#       --output-file requirements-ci.txt requirements-ci.in
#
# Versions here are kept in sync with DBR 17.3 LTS where applicable; see
# scripts/docker/Dockerfile ENV block and gbx:versions:audit. GDAL is NOT
# included — it's installed separately with a version detected from the
# system's `gdal-config --version` to match the apt-installed native.
build==1.4.4
cython==3.0.12
numpy==2.1.3
pyspark==4.0.0
pytest==8.4.2
pytest-cov==7.1.0
setuptools==80.9.0  # >= 77.0.0 required to parse PEP 639 SPDX license strings (GDAL 3.11+ sdist's `license = "MIT"`); 74.0.0 fails GDAL build with `project.license must be valid exactly by one definition`
wheel==0.45.1

# from pyproject.toml [dev] extra (lint tooling)
# Versions pinned for deterministic lockfile regeneration. Bump as needed;
# the hash-pin in requirements-ci.txt is what enforces supply-chain integrity.
isort==8.0.1
black==26.3.1
flake8==7.3.0
flake8-pyproject==1.2.4
