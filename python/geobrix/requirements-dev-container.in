# Source of truth for the geobrix-dev Docker image's Python deps.
# Consumed by scripts/docker/Dockerfile via:
#   pip install --require-hashes -r python/geobrix/requirements-dev-container.txt
#
# Regenerate the hash-pinned lock alongside any edit:
#   docker exec -it geobrix-dev bash -lc \
#     'cd /root/geobrix/python/geobrix && \
#      uv pip compile --generate-hashes --python-version 3.12 \
#         --output-file requirements-dev-container.txt requirements-dev-container.in'
#
# All versions match scripts/docker/Dockerfile's ENV block (DBR 17.3 LTS-aligned
# where applicable). GDAL is NOT included — it's built from source and the
# Python binding is installed against the local gdal-config --version.
#
# Bump procedure: edit a pin, regenerate the .txt, rebuild the image with
# `scripts/docker/build_smart.sh --no-cache`, smoke-test.

# --- toolchain ---
pip==25.0.1
setuptools==74.0.0
wheel==0.45.1
cython==3.0.12
build==1.4.4

