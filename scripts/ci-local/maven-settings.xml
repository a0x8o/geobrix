<!--
Maven settings baked into the local-act runner image.
The <mirror> url is injected at image build time from $MAVEN_MIRROR_URL on
the host (see Dockerfile.gha-runner). Set $MAVEN_MIRROR_URL to point at a
private mirror if your network requires one; leave it unset to use Maven
Central.
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 http://maven.apache.org/xsd/settings-1.2.0.xsd">
</settings>
